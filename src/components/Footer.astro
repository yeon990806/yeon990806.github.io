---
import { SITE_AUTHOR, SOCIAL_LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="accent-line" aria-hidden="true"></div>
  <div class="footer-inner">
    <div class="brand">
      <span class="mark" aria-hidden="true">y.</span>
      <div class="brand-text">
        <p class="brand-name">yeon.dev</p>
        <p class="brand-tag">매일 한 줄씩. © {year}</p>
      </div>
    </div>
    <ul class="links">
      <li><a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">GitHub <span class="arrow">↗</span></a></li>
      <li><a href={SOCIAL_LINKS.email}>Email</a></li>
      <li><a href={SOCIAL_LINKS.rss}>RSS</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    position: relative;
    padding: 2.5rem 1.5rem 3rem;
    color: var(--color-muted);
    font-size: 0.875rem;
  }
  .accent-line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 64rem;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-border-strong) 20%, var(--color-border-strong) 80%, transparent 100%);
  }
  .footer-inner {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--color-accent), oklch(60% 0.2 200));
    color: var(--color-accent-fg);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1.3; }
  .brand-name {
    margin: 0;
    color: var(--color-fg);
    font-family: var(--font-display);
    font-weight: 600;
  }
  .brand-tag { margin: 0; font-size: 0.75rem; }
  .links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .links a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .links a:hover { color: var(--color-fg); }
  .arrow { display: inline-block; transform: translateY(-1px); margin-left: 2px; }
</style>
