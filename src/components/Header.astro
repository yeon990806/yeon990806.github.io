---
import { SITE_TITLE, NAV_ITEMS } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import SearchTrigger from './SearchTrigger.astro';
---

<header class="site-header">
  <nav class="glass nav">
    <a href="/" class="brand" aria-label={SITE_TITLE}>
      <span class="brand-mark" aria-hidden="true">y.</span>
      <span class="brand-name">{SITE_TITLE}</span>
    </a>

    <div class="nav-links">
      {NAV_ITEMS.map((item) => (
        <HeaderLink href={item.href}>{item.label}</HeaderLink>
      ))}
    </div>

    <div class="nav-tools">
      <SearchTrigger />
      <ThemeToggle />
    </div>

    <button
      id="mobile-menu-toggle"
      type="button"
      class="mobile-toggle"
      aria-label="메뉴 열기"
      aria-expanded="false"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="mobile-menu glass" hidden>
    {NAV_ITEMS.map((item) => (
      <HeaderLink href={item.href} class="mobile-link">{item.label}</HeaderLink>
    ))}
    <div class="mobile-tools">
      <SearchTrigger />
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0.75rem 1rem 0;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.5rem 0.75rem 0.5rem 1rem;
    border-radius: 9999px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-fg);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--color-accent), oklch(60% 0.2 200));
    color: var(--color-accent-fg);
    font-size: 0.85rem;
    font-weight: 700;
    box-shadow: 0 1px 3px color-mix(in oklch, var(--color-accent) 30%, transparent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    margin-left: 0.5rem;
  }
  .nav-tools {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .mobile-toggle {
    display: none;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    margin-left: auto;
    border-radius: 9999px;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    cursor: pointer;
  }
  .mobile-toggle svg { width: 1.1rem; height: 1.1rem; }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 72rem;
    margin: 0.5rem auto 0;
    padding: 0.75rem;
    border-radius: 1rem;
  }
  .mobile-menu[hidden] { display: none !important; }
  .mobile-menu:not([hidden]) { display: flex; }
  .mobile-link {
    height: auto;
    padding: 0.65rem 0.75rem;
    font-size: 0.95rem;
  }
  .mobile-tools {
    display: flex;
    gap: 0.5rem;
    padding: 0.5rem 0.25rem 0;
    border-top: 1px solid var(--color-border);
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .nav-links, .nav-tools { display: none; }
    .mobile-toggle { display: inline-flex; }
  }
</style>

<script>
  function bindMobileMenu() {
    const btn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu || btn.dataset.bound === 'true') return;
    btn.dataset.bound = 'true';
    btn.addEventListener('click', () => {
      const open = menu.hasAttribute('hidden');
      if (open) {
        menu.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
      } else {
        menu.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  }
  bindMobileMenu();
  document.addEventListener('astro:page-load', bindMobileMenu);
</script>
