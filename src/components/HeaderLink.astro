---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const hrefStr = String(href ?? '');
const hrefNormalized = hrefStr.replace(/\/$/, '') || '/';

const isActive =
  hrefNormalized === '/'
    ? pathname === '/'
    : pathname === hrefNormalized || pathname.startsWith(hrefNormalized + '/');
---

<a href={href} class:list={['header-link', className, { active: isActive }]} {...props}>
  <slot />
</a>

<style>
  .header-link {
    display: inline-flex;
    align-items: center;
    height: 2.25rem;
    padding: 0 0.6rem;
    border-radius: 0.5rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }
  .header-link:hover {
    color: var(--color-fg);
    background: color-mix(in oklch, var(--color-surface) 60%, transparent);
  }
  .header-link.active {
    color: var(--color-fg);
    background: color-mix(in oklch, var(--color-fg) 6%, transparent);
  }
</style>
