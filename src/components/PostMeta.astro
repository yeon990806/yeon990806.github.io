---
import FormattedDate from './FormattedDate.astro';

interface Props {
  pubDate: Date;
  updatedDate?: Date;
  readingMinutes: number;
  tags?: string[];
}

const { pubDate, updatedDate, readingMinutes, tags = [] } = Astro.props;
---

<div class="meta">
  <FormattedDate date={pubDate} />
  {updatedDate && (
    <span class="updated">· {`${new Date(updatedDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}`} 업데이트</span>
  )}
  <span class="dot">·</span>
  <span>{readingMinutes}분 읽기</span>
  {tags.length > 0 && (
    <>
      <span class="dot">·</span>
      <ul class="tags">
        {tags.map((tag) => (
          <li><a href={`/tags/${encodeURIComponent(tag)}/`} class="pill">#{tag}</a></li>
        ))}
      </ul>
    </>
  )}
</div>

<style>
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.875rem;
  }
  .dot { opacity: 0.5; }
  .updated { font-size: 0.8125rem; }
  .tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
