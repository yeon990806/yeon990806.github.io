---
import { Image } from 'astro:assets';

interface Props {
  href: string;
  title: string;
  description: string;
  period: string;
  role?: string;
  status: 'live' | 'archived' | 'wip';
  tags: string[];
  heroImage?: ImageMetadata;
}

const { href, title, description, period, role, status, tags, heroImage } = Astro.props;

const statusLabel = {
  live: 'Live',
  archived: 'Archived',
  wip: 'WIP',
};
---

<a href={href} class="project-card surface surface-hover">
  {heroImage && (
    <div class="hero">
      <Image src={heroImage} alt="" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" />
    </div>
  )}
  <div class="body">
    <div class="meta">
      <span class={`status status-${status}`}>{statusLabel[status]}</span>
      <span class="period">{period}</span>
      {role && <span class="role">· {role}</span>}
    </div>
    <h3 class="title">{title}</h3>
    <p class="desc">{description}</p>
    {tags.length > 0 && (
      <ul class="tags">
        {tags.slice(0, 5).map((t) => <li class="tag">{t}</li>)}
      </ul>
    )}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .hero {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: color-mix(in oklch, var(--color-surface) 70%, transparent);
    border-bottom: 1px solid var(--color-border);
  }
  .hero :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    border-radius: 0;
  }
  .project-card:hover .hero :global(img) { transform: scale(1.03); }

  .body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .status {
    padding: 0.1rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .status-live {
    background: color-mix(in oklch, oklch(65% 0.18 150) 18%, transparent);
    color: oklch(45% 0.18 150);
  }
  .status-wip {
    background: color-mix(in oklch, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
  }
  .status-archived {
    background: color-mix(in oklch, var(--color-fg) 8%, transparent);
    color: var(--color-muted);
  }
  :global([data-theme="dark"]) .status-live { color: oklch(75% 0.18 150); }

  .period { font-variant-numeric: tabular-nums; }

  .title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 650;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-fg);
  }

  .desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0.25rem 0 0;
    padding: 0;
    list-style: none;
  }
  .tag {
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    background: color-mix(in oklch, var(--color-surface) 60%, transparent);
    border: 1px solid var(--color-border);
    font-size: 0.72rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
  }
</style>
