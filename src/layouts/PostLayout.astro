---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import PostMeta from '../components/PostMeta.astro';
import Toc from '../components/Toc.astro';
import CodeCopy from '../components/CodeCopy.astro';
import PostNav from '../components/PostNav.astro';
import Giscus from '../components/Giscus.astro';
import { readingTime } from '../utils/readingTime';

interface Props {
  entry: CollectionEntry<'posts'>;
  headings: Array<{ depth: number; slug: string; text: string }>;
  body?: string;
  prev?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
}

const { entry, headings, body, prev, next } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags, series } = entry.data;
const minutes = readingTime(body);
---

<Base title={title} description={description} ogImage={`/og/posts/${entry.id}.png`}>
  <article class="post container-wide">
    <header class="post-header">
      {series && (
        <p class="series">
          <span class="series-label">시리즈</span>
          <span class="series-name">{series}</span>
        </p>
      )}
      <h1 class="post-title">{title}</h1>
      <PostMeta
        pubDate={pubDate}
        updatedDate={updatedDate}
        readingMinutes={minutes}
        tags={tags}
      />
      {heroImage && (
        <div class="post-hero">
          <Image src={heroImage} alt="" widths={[640, 960, 1280]} sizes="(max-width: 768px) 100vw, 720px" />
        </div>
      )}
    </header>

    <div class="post-body">
      {headings && headings.length > 0 && (
        <aside class="post-toc" aria-label="목차 사이드바">
          <div class="toc-sticky">
            <Toc headings={headings} />
          </div>
        </aside>
      )}

      <div class="prose">
        <slot />
      </div>
    </div>

    <PostNav prev={prev} next={next} />

    <section class="comments">
      <h2 class="comments-title">댓글</h2>
      <Giscus />
    </section>
  </article>

  <CodeCopy />
</Base>

<style>
  .post {
    padding: 3rem 1.25rem 2rem;
  }

  .post-header {
    max-width: var(--reading-width);
    margin: 0 auto 2.5rem;
    text-align: left;
  }

  .series {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    color: var(--color-accent);
    font-size: 0.875rem;
  }
  .series-label {
    padding: 0.1rem 0.5rem;
    border-radius: 9999px;
    background: color-mix(in oklch, var(--color-accent) 12%, transparent);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 1.25rem + 2.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }

  .post-hero {
    margin: 2rem 0 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .post-hero :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
  }

  /* Two-column layout: TOC on the left, article on the right.
     Collapses to single column under 1024px.
     NOTE: grid uses default `align-items: stretch` so the TOC column
     fills the full body height — sticky needs room to scroll within. */
  .post-body {
    display: grid;
    grid-template-columns: 14rem minmax(0, var(--reading-width));
    gap: 3rem;
    justify-content: center;
  }
  .post-toc {
    position: relative;
    height: 100%;
  }
  .toc-sticky {
    position: sticky;
    top: 5rem;
    max-height: calc(100dvh - 7rem);
    overflow-y: auto;
  }

  @media (max-width: 1024px) {
    .post-body {
      grid-template-columns: minmax(0, var(--reading-width));
    }
    .post-toc { display: none; }
  }

  /* Prose — clean text on body bg, no surrounding card.
     Notion / Linear-style: typography is the focus. */
  .prose {
    font-size: 1.125rem;
    line-height: 1.85;
    color: var(--color-fg);
  }
  .prose :global(h2) {
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.018em;
    scroll-margin-top: 5rem;
  }
  .prose :global(h3) {
    margin-top: 2.25rem;
    margin-bottom: 0.85rem;
    font-size: 1.25rem;
    font-weight: 650;
    letter-spacing: -0.012em;
    scroll-margin-top: 5rem;
  }
  .prose :global(h4) {
    margin-top: 1.75rem;
    margin-bottom: 0.6rem;
    font-size: 1.1rem;
    font-weight: 600;
    scroll-margin-top: 5rem;
  }
  .prose :global(p) {
    margin-bottom: 1.3em;
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-fg);
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.1em;
  }
  .prose :global(li) { margin-bottom: 0.35em; }
  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin-top: 0.35em;
    margin-bottom: 0;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.95em;
  }
  .prose :global(th),
  .prose :global(td) {
    padding: 0.55em 0.85em;
    border-bottom: 1px solid var(--color-border);
    text-align: left;
  }
  .prose :global(thead th) {
    background: color-mix(in oklch, var(--color-surface) 60%, transparent);
    font-weight: 600;
  }
  .prose :global(blockquote p:last-child) { margin-bottom: 0; }
  .prose :global(img) {
    margin: 1.5em auto;
    display: block;
  }

  .comments {
    max-width: var(--reading-width);
    margin: 4rem auto 0;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }
  .comments-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .muted { color: var(--color-muted); }
</style>
