---
import Base from '../layouts/Base.astro';
import { SOCIAL_LINKS } from '../consts';

/* ============================================================
   ABOUT 페이지 데이터.
   여기만 편집하세요. 아래 템플릿이 자동으로 렌더링합니다.

   - 비울 필드: 빈 문자열 '' 또는 빈 배열 [] → 해당 부분 자동 숨김
   - 줄바꿈: bio/now는 배열로, 각 원소가 한 문단
   - 대괄호 [예시 텍스트] 는 placeholder — 본인 정보로 교체
   ============================================================ */
const ABOUT = {
  // 한 줄 자기소개 (hero에 큰 글씨로)
  tagline: '실용주의 개발자. 매일 조금씩 쌓는 중.',

  // 거주/활동 지역 (옵션, hero 칩). 비우려면 ''
  location: '[서울 / Remote 등]',

  // 짧은 자기 서사 (1~2문단 권장)
  bio: [
    '안녕하세요, **yeon**입니다.',
    '[자기소개 첫 문단 — 어떤 일을 해왔고 지금 무엇에 관심 있는지 2~3문장.]',
    '[두 번째 문단 — 가치관, 일하는 방식, 또는 사이드 관심사. 굳이 길지 않아도 OK.]',
  ],

  // 경력 — 최신순으로. 비우면 섹션 숨김.
  // role 안에 회사/역할/포지션을 자유롭게.
  career: [
    {
      period: '[2024 - 2026]',
      role: '[회사명] · [직책 / 역할]',
      highlights: [
        '[핵심 성과 1 — 가능하면 숫자로]',
        '[핵심 성과 2]',
      ],
    },
    {
      period: '[2022 - 2024]',
      role: '[이전 회사] · [직책]',
      highlights: [
        '[핵심 성과 1]',
      ],
    },
  ],

  // 기술 스택. 비우려면 빈 배열 [].
  skills: {
    primary: ['[TypeScript]', '[React / Next.js]', '[주력 3~5개]'],
    side: ['[관심 1]', '[관심 2]'],
  },

  // 자격증·교육. 비우면 섹션 숨김.
  certs: {
    have: ['[보유 자격증 1]', '[보유 자격증 2]'],
    pursuing: ['[7월부터 준비할 자격증]'],
    education: ['[학력 또는 부트캠프 등 — 옵션]'],
  },

  // "지금" — 사이트의 /now 페이지 역할을 about에 통합.
  // 1~2 문단. 7월부터의 목표를 여기에 자연스럽게.
  now: [
    '[현재 진행 중인 일 — 예: "yeon.dev 블로그 재작성, 자격증 X 공부, 사이드 프로젝트 Y."]',
    '[7월 1일부터의 단기 목표 — 비공식적으로 적어도 OK.]',
  ],
};

const hasCareer = ABOUT.career.length > 0;
const hasCerts =
  ABOUT.certs.have.length + ABOUT.certs.pursuing.length + ABOUT.certs.education.length > 0;
const hasNow = ABOUT.now.length > 0;
---

<Base title="About" description={ABOUT.tagline}>
  <article class="about">
    <!-- Hero -->
    <header class="intro reading">
      <h1 class="title">About</h1>
      <p class="tagline" set:html={ABOUT.tagline}></p>
      <div class="chips">
        {ABOUT.location && <span class="chip">📍 {ABOUT.location}</span>}
        <a class="chip link" href={SOCIAL_LINKS.email}>✉ Email</a>
        <a class="chip link" href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">GitHub ↗</a>
      </div>
    </header>

    <!-- Bio -->
    {ABOUT.bio.length > 0 && (
      <section class="section reading">
        {ABOUT.bio.map((p) => (
          <p class="bio" set:html={p.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}></p>
        ))}
      </section>
    )}

    <!-- Career -->
    {hasCareer && (
      <section class="section reading">
        <h2 class="section-title">경력</h2>
        <ol class="timeline">
          {ABOUT.career.map((c) => (
            <li class="timeline-item">
              <div class="period">{c.period}</div>
              <div class="role-block">
                <p class="role">{c.role}</p>
                {c.highlights.length > 0 && (
                  <ul class="highlights">
                    {c.highlights.map((h) => <li>{h}</li>)}
                  </ul>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Skills -->
    {(ABOUT.skills.primary.length > 0 || ABOUT.skills.side.length > 0) && (
      <section class="section reading">
        <h2 class="section-title">기술</h2>
        {ABOUT.skills.primary.length > 0 && (
          <div class="skill-group">
            <h3 class="skill-label">주력</h3>
            <ul class="chip-row">
              {ABOUT.skills.primary.map((s) => <li class="chip">{s}</li>)}
            </ul>
          </div>
        )}
        {ABOUT.skills.side.length > 0 && (
          <div class="skill-group">
            <h3 class="skill-label">사이드 · 관심</h3>
            <ul class="chip-row">
              {ABOUT.skills.side.map((s) => <li class="chip muted">{s}</li>)}
            </ul>
          </div>
        )}
      </section>
    )}

    <!-- Certs -->
    {hasCerts && (
      <section class="section reading">
        <h2 class="section-title">자격증 · 교육</h2>
        {ABOUT.certs.have.length > 0 && (
          <div class="cert-group">
            <h3 class="cert-label">보유</h3>
            <ul class="cert-list">
              {ABOUT.certs.have.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
        {ABOUT.certs.pursuing.length > 0 && (
          <div class="cert-group">
            <h3 class="cert-label">준비 중</h3>
            <ul class="cert-list">
              {ABOUT.certs.pursuing.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
        {ABOUT.certs.education.length > 0 && (
          <div class="cert-group">
            <h3 class="cert-label">교육</h3>
            <ul class="cert-list">
              {ABOUT.certs.education.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
      </section>
    )}

    <!-- Now -->
    {hasNow && (
      <section class="section reading">
        <h2 class="section-title">지금</h2>
        <div class="glass now-card">
          {ABOUT.now.map((p) => <p>{p}</p>)}
        </div>
      </section>
    )}

    <!-- Contact -->
    <section class="section reading contact-section">
      <h2 class="section-title">연락</h2>
      <ul class="contact">
        <li>
          <a href={SOCIAL_LINKS.email}>✉ {SOCIAL_LINKS.email.replace('mailto:', '')}</a>
        </li>
        <li>
          <a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">
            ↗ {SOCIAL_LINKS.github.replace('https://', '')}
          </a>
        </li>
        <li>
          <a href={SOCIAL_LINKS.rss}>RSS 피드</a>
        </li>
      </ul>
    </section>
  </article>
</Base>

<style>
  .about { padding: 3rem 0 1rem; }

  .reading {
    max-width: var(--reading-width);
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  /* Hero */
  .intro {
    text-align: left;
    margin-bottom: 3rem;
  }
  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 1.5vw, 2.5rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .tagline {
    margin: 0 0 1.25rem;
    color: var(--color-fg);
    font-size: 1.15rem;
    line-height: 1.5;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background: color-mix(in oklch, var(--color-surface) 60%, transparent);
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .chip.link {
    color: var(--color-fg);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .chip.link:hover {
    border-color: color-mix(in oklch, var(--color-fg) 25%, transparent);
    color: var(--color-accent);
  }

  /* Sections */
  .section { margin-bottom: 3rem; }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Bio */
  .bio {
    margin: 0 0 0.85em;
    font-size: 1.025rem;
    line-height: 1.75;
  }
  .bio:last-child { margin-bottom: 0; }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .period {
    color: var(--color-muted);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    padding-top: 0.15rem;
  }
  .role-block { margin: 0; }
  .role {
    margin: 0 0 0.4rem;
    font-weight: 600;
    color: var(--color-fg);
  }
  .highlights {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-muted);
  }
  .highlights li {
    margin-bottom: 0.25rem;
    line-height: 1.55;
  }
  @media (max-width: 640px) {
    .timeline-item { grid-template-columns: 1fr; gap: 0.35rem; }
  }

  /* Skills */
  .skill-group + .skill-group { margin-top: 1.25rem; }
  .skill-label,
  .cert-label {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .chip-row .chip {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.2rem 0.65rem;
  }
  .chip-row .chip.muted { color: var(--color-muted); }

  /* Certs */
  .cert-group + .cert-group { margin-top: 1.25rem; }
  .cert-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cert-list li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .cert-list li:last-child { border-bottom: 0; }

  /* Now card */
  .now-card {
    padding: 1.5rem 1.75rem;
    border-radius: var(--radius-lg);
  }
  .now-card p {
    margin: 0 0 0.75em;
    line-height: 1.7;
  }
  .now-card p:last-child { margin-bottom: 0; }

  /* Contact */
  .contact-section { margin-bottom: 5rem; }
  .contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .contact a {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: 0.15rem;
    transition: color 0.15s, border-color 0.15s;
  }
  .contact a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>
