---
import Base from '../layouts/Base.astro';
import { SOCIAL_LINKS } from '../consts';

/* ============================================================
   ABOUT 페이지 데이터.
   여기만 편집하면 페이지가 자동으로 새로 그려집니다.
   bio·now는 배열 (한 원소 = 한 문단), 빈 배열은 섹션 자동 숨김.
   ============================================================ */
const ABOUT = {
  tagline:
    '퍼블리셔로 시작해, 지금은 웹·앱·솔루션을 만드는 풀스택 개발자.',

  location: '대한민국',

  bio: [
    '안녕하세요, **김도연** (yeon) 입니다.',
    '2017년 퍼블리셔로 시작해 사용자 경험에 집착하는 UI를 만들다가, 1금융권과 공공기관 SI, R&D 솔루션 프로젝트를 거치며 비즈니스 로직까지 다루는 풀스택 개발자로 성장했습니다.',
    '투네이션에서 대규모 트래픽 환경의 프론트엔드와 서비스 개발을 담당했고, CI/CD 파이프라인을 직접 구축해 운영했습니다. 최근 1년 6개월은 하울링에서 전자 계약 · 근태 관리 · 3PL WMS/OMS 솔루션을 Web과 Flutter 기반 모바일까지 동시에 만들면서, 웹과 모바일을 아우르는 풀스택으로 영역을 넓혔습니다.',
    '요즘은 **AX(AI Experience)** 에 대한 고민과 함께, 프로덕트 디자이너의 관점에서 서비스를 다루는 방향도 같이 공부하고 있습니다.',
  ],

  career: [
    {
      period: '2025.01 - 2026.06',
      role: '(주)하울링 · 개발팀 엔지니어',
      highlights: [
        '일용직 근로자 특화 전자 계약 서비스 — <code>WINK</code>',
        '근태 관리 통합 플랫폼 (Web · Flutter) — <code>WINK WORKER</code>',
        '3PL WMS · OMS 통합 솔루션 — <code>DOODA</code>',
      ],
    },
    {
      period: '2021.02 - 2024.12',
      role: '(주)투네이션 · 개발본부 Staff',
      highlights: [
        'Flutter PoC 리모컨 현대화',
        '치지직(Chzzk) · 투네AD 클라이언트 리모컨',
        '투네이션 Play Web 2차 고도화',
        'HTML5 Custom Elements 관리자 UI Kit',
        '글로벌 다국어 언어팩 인프라',
        '정산 시스템 대규모 개편',
        '가챠온(Gachaon) · 퀴즈킹(QuizKing)',
      ],
    },
    {
      period: '2020.07 - 2021.02',
      role: '(주)알파이글루 · 연구원',
      highlights: [
        '알파키친(Alpha Kitchen) 식사 주문 서비스',
        '실시간 캠 기반 학습 시간 측정 PoC',
      ],
    },
    {
      period: '2020.03 - 2020.07',
      role: '에프티앤씨(주) · 연구원',
      highlights: [
        '잇올(It-all) 공식 홈페이지 리뉴얼 및 퍼블리싱',
      ],
    },
    {
      period: '2017.09 - 2020.03',
      role: '(주)인젠트 · 퍼블리셔 / 프론트엔드',
      highlights: [
        'i-biz 사내 ERP 인사관리(HR) 시스템',
        'iXeb HTML5 WYSIWYG Framework',
        'IBK 기업은행 차세대 VTM',
        'KB 국민은행 차세대 PoC',
        '공공기관·금융권 메인 퍼블리싱',
      ],
    },
  ],

  skills: {
    primary: [
      'TypeScript',
      'React',
      'Next.js',
      'Vue.js',
      'Flutter',
      'HTML / CSS',
    ],
    side: [
      'Zustand',
      'Astro',
      'Node.js',
      'Java / Spring',
      'PHP',
      'Firebase',
      'RESTful API',
      'CI/CD',
      'Figma',
    ],
  },

  certs: {
    have: [
      '정보처리기능사',
      'OCJP (Oracle Certified Java Programmer)',
      '웹디자인기능사',
    ],
    pursuing: [],
    education: [
      '단국대학교 · 산업경영 학사 (2023 - 재학 중)',
      '양영디지털고등학교 (2015 - 2018)',
    ],
  },

  now: [],
};

const hasCareer = ABOUT.career.length > 0;
const hasCerts =
  ABOUT.certs.have.length + ABOUT.certs.pursuing.length + ABOUT.certs.education.length > 0;
const hasNow = ABOUT.now.length > 0;
---

<Base title="About" description={ABOUT.tagline}>
  <article class="about">
    <!-- Hero -->
    <header class="intro reading">
      <h1 class="title">About</h1>
      <p class="tagline" set:html={ABOUT.tagline}></p>
      <div class="chips">
        {ABOUT.location && <span class="chip">📍 {ABOUT.location}</span>}
        <a class="chip link" href={SOCIAL_LINKS.email}>✉ Email</a>
        <a class="chip link" href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">GitHub ↗</a>
      </div>
    </header>

    <!-- Bio -->
    {ABOUT.bio.length > 0 && (
      <section class="section reading">
        {ABOUT.bio.map((p) => (
          <p class="bio" set:html={p.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}></p>
        ))}
      </section>
    )}

    <!-- Career -->
    {hasCareer && (
      <section class="section reading">
        <h2 class="section-title">경력</h2>
        <ol class="timeline">
          {ABOUT.career.map((c) => (
            <li class="timeline-item">
              <div class="period">{c.period}</div>
              <div class="role-block">
                <p class="role">{c.role}</p>
                {c.highlights.length > 0 && (
                  <ul class="highlights">
                    {c.highlights.map((h) => <li set:html={h}></li>)}
                  </ul>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Skills -->
    {(ABOUT.skills.primary.length > 0 || ABOUT.skills.side.length > 0) && (
      <section class="section reading">
        <h2 class="section-title">기술</h2>
        {ABOUT.skills.primary.length > 0 && (
          <div class="skill-group">
            <h3 class="skill-label">주력</h3>
            <ul class="chip-row">
              {ABOUT.skills.primary.map((s) => <li class="chip">{s}</li>)}
            </ul>
          </div>
        )}
        {ABOUT.skills.side.length > 0 && (
          <div class="skill-group">
            <h3 class="skill-label">사이드 · 관심</h3>
            <ul class="chip-row">
              {ABOUT.skills.side.map((s) => <li class="chip muted">{s}</li>)}
            </ul>
          </div>
        )}
      </section>
    )}

    <!-- Certs -->
    {hasCerts && (
      <section class="section reading">
        <h2 class="section-title">자격증 · 교육</h2>
        {ABOUT.certs.have.length > 0 && (
          <div class="cert-group">
            <h3 class="cert-label">보유</h3>
            <ul class="cert-list">
              {ABOUT.certs.have.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
        {ABOUT.certs.pursuing.length > 0 && (
          <div class="cert-group">
            <h3 class="cert-label">준비 중</h3>
            <ul class="cert-list">
              {ABOUT.certs.pursuing.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
        {ABOUT.certs.education.length > 0 && (
          <div class="cert-group">
            <h3 class="cert-label">교육</h3>
            <ul class="cert-list">
              {ABOUT.certs.education.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
      </section>
    )}

    <!-- Now -->
    {hasNow && (
      <section class="section reading">
        <h2 class="section-title">지금</h2>
        <div class="surface now-card">
          {ABOUT.now.map((p) => <p>{p}</p>)}
        </div>
      </section>
    )}

    <!-- Contact -->
    <section class="section reading contact-section">
      <h2 class="section-title">연락</h2>
      <ul class="contact">
        <li>
          <a href={SOCIAL_LINKS.email}>✉ {SOCIAL_LINKS.email.replace('mailto:', '')}</a>
        </li>
        <li>
          <a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">
            ↗ {SOCIAL_LINKS.github.replace('https://', '')}
          </a>
        </li>
        <li>
          <a href={SOCIAL_LINKS.rss}>RSS 피드</a>
        </li>
      </ul>
    </section>
  </article>
</Base>

<style>
  .about { padding: 3rem 0 1rem; }

  .reading {
    max-width: var(--reading-width);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* Hero */
  .intro {
    text-align: left;
    margin-bottom: 3rem;
  }
  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 1.5vw, 2.5rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .tagline {
    margin: 0 0 1.25rem;
    color: var(--color-fg);
    font-size: 1.15rem;
    line-height: 1.55;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background: var(--color-surface-subtle);
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .chip.link {
    color: var(--color-fg);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .chip.link:hover {
    border-color: var(--color-border-strong);
    color: var(--color-accent);
  }

  /* Sections */
  .section { margin-bottom: 3rem; }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .section-title::before {
    content: "";
    display: inline-block;
    width: 0.35rem;
    height: 1.05rem;
    border-radius: 2px;
    background: linear-gradient(180deg, var(--color-accent), oklch(60% 0.2 200));
  }

  /* Bio */
  .bio {
    margin: 0 0 0.95em;
    font-size: 1.05rem;
    line-height: 1.8;
  }
  .bio:last-child { margin-bottom: 0; }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .period {
    color: var(--color-muted);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    padding-top: 0.15rem;
  }
  .role-block { margin: 0; }
  .role {
    margin: 0 0 0.5rem;
    font-weight: 650;
    color: var(--color-fg);
  }
  .highlights {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-muted);
  }
  .highlights li {
    margin-bottom: 0.35rem;
    line-height: 1.6;
  }
  .highlights :global(code) {
    font-family: var(--font-mono);
    font-size: 0.78em;
    padding: 0.1em 0.45em;
    margin-left: 0.15em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.3em;
    color: var(--color-fg);
    letter-spacing: 0.02em;
  }
  @media (max-width: 640px) {
    .timeline-item { grid-template-columns: 1fr; gap: 0.35rem; }
  }

  /* Skills */
  .skill-group + .skill-group { margin-top: 1.25rem; }
  .skill-label,
  .cert-label {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .chip-row .chip {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.2rem 0.65rem;
  }
  .chip-row .chip.muted { color: var(--color-muted); }

  /* Certs */
  .cert-group + .cert-group { margin-top: 1.25rem; }
  .cert-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cert-list li {
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .cert-list li:last-child { border-bottom: 0; }

  /* Now card */
  .now-card {
    padding: 1.75rem 1.85rem;
  }
  .now-card p {
    margin: 0 0 0.75em;
    line-height: 1.7;
  }
  .now-card p:last-child { margin-bottom: 0; }

  /* Contact */
  .contact-section { margin-bottom: 5rem; }
  .contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact a {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: 0.15rem;
    transition: color 0.15s, border-color 0.15s;
  }
  .contact a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>
