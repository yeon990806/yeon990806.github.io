---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import PostLayout from '../../layouts/PostLayout.astro';

export const getStaticPaths = (async () => {
  const showDrafts = import.meta.env.DEV;
  const all = await getCollection('posts', ({ data }) => showDrafts || !data.draft);

  // Pre-compute series-aware prev/next.
  // Within a series: order by seriesOrder. Outside: no prev/next.
  const seriesGroups = new Map<string, typeof all>();
  for (const p of all) {
    if (!p.data.series) continue;
    if (!seriesGroups.has(p.data.series)) seriesGroups.set(p.data.series, []);
    seriesGroups.get(p.data.series)!.push(p);
  }
  for (const list of seriesGroups.values()) {
    list.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
  }

  return all.map((entry) => {
    let prev: typeof entry | undefined;
    let next: typeof entry | undefined;
    if (entry.data.series) {
      const list = seriesGroups.get(entry.data.series)!;
      const i = list.findIndex((p) => p.id === entry.id);
      prev = i > 0 ? list[i - 1] : undefined;
      next = i < list.length - 1 ? list[i + 1] : undefined;
    }
    return { params: { slug: entry.id }, props: { entry, prev, next } };
  });
}) satisfies GetStaticPaths;

const { entry, prev, next } = Astro.props;
const { Content, headings } = await render(entry);
---

<PostLayout entry={entry} headings={headings} body={entry.body} prev={prev} next={next}>
  <Content />
</PostLayout>
